generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String   @id @default(uuid())
  supabaseId        String?  @unique  // Supabase Auth user UUID
  email             String   @unique
  username          String?  @unique
  displayName       String?            // Human-friendly name (synced from Supabase user_metadata.full_name)
  password          String?            // Legacy — kept for backward compat
  role              String   @default("user") // "user" | "admin"
  telegramId        String?  @unique          // Telegram user ID stored as string (BigInt overflows PG bigint)
  telegramUsername  String?                   // Telegram @username
  xId               String?  @unique          // Twitter/X user ID (from identity_data.sub)
  xHandle           String?                   // Twitter/X username (from identity_data.user_name)
  xAccessToken      String?                   // X OAuth2 access token (2h lifetime)
  xRefreshToken     String?                   // X OAuth2 refresh token (one-time use, 6mo)
  xTokenExpiry      DateTime?                 // When the X access token expires
  discordId         String?  @unique          // Discord user ID
  discordHandle     String?                   // Discord username
  discordAccessToken  String?                 // Discord OAuth access token (guilds.members.read)
  discordRefreshToken String?                 // Discord OAuth refresh token
  discordTokenExpiry  DateTime?               // When the access token expires
  githubId            String?  @unique        // GitHub user numeric ID
  githubHandle        String?                 // GitHub @username
  githubAccessToken   String?                 // GitHub OAuth access token (repo scope for creators)

  xp                Int      @default(0)        // experience points — used for quest ranking
  rank              Int      @default(0)        // leaderboard rank derived from xp
  userType          String   @default("standard") // "standard" | "premium" | "og_pioneer" | "early_access"

  // Stripe Connect — for receiving fiat payouts as winner
  stripeConnectedAccountId  String?   @unique  // Stripe Express account ID (acct_xxx)
  stripeConnectedOnboarded  Boolean   @default(false)
  // Stripe Customer — for paying as sponsor
  stripeCustomerId          String?   @unique  // Stripe customer ID (cus_xxx)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  agents         Agent[]
  wallets        WalletLink[]
  participations QuestParticipation[]
  collaborations QuestCollaborator[]
  questDeposits  QuestDeposit[]
  waitlistEntry  WaitlistEntry?
  githubBounties GitHubBounty[]
  githubBountySubmissions GitHubBountySubmission[]
  sponsoredQuests Quest[]  @relation("SponsoredQuests")
  skillSubmissions    web3_skill_submissions[] @relation("SkillSubmitter")
  skillReviews        web3_skill_submissions[] @relation("SkillReviewer")
}

model Agent {
  id                    String    @id @default(uuid())
  ownerId               String?
  owner                 User?     @relation(fields: [ownerId], references: [id])
  agentname             String
  status                String    @default("idle") // idle, questing, offline
  activationCode        String?   @unique
  agentApiKey           String?   @unique  // issued on /agents/register — used by agents as Bearer token
  verificationToken     String?   @unique  // for agent-first registration claim flow
  verificationExpiresAt DateTime?           // 48h expiry for verification token

  claimedAt             DateTime?           // null = unclaimed
  claimedVia            String?             // "telegram" | "email" | "supabase"
  claimEmail            String?             // email used to claim (if email flow)

  TelegramLink   TelegramLink?
  logs           AgentLog[]
  participations QuestParticipation[]
  skills         AgentSkill[]
  githubBountySubmissions GitHubBountySubmission[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([ownerId])
  @@index([agentApiKey])
  @@index([verificationToken])
}

model TelegramLink {
  id          String   @id @default(uuid())
  agentId     String   @unique
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  telegramId  BigInt               // one Telegram user can claim multiple agents
  username    String?
  firstName   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([telegramId])
}

model Quest {
  id          String   @id @default(uuid())
  title       String
  description String
  sponsor     String   @default("System")
  sponsorId   String?  @db.Uuid
  sponsorUser User?    @relation("SponsoredQuests", fields: [sponsorId], references: [id])

  type        String   @default("FCFS") // FCFS, LEADERBOARD, LUCKY_DRAW
  status      String   @default("draft") // draft, live, scheduled, completed, cancelled, expired

  rewardAmount Decimal  @default(0) @db.Decimal(36, 18)
  rewardType   String   @default("USDC") // USDC | LLMTOKEN_OPENROUTER
  tokenProvider String?              // "openrouter" — for LLM token rewards
  tokenAmount   Decimal? @db.Decimal(36, 18) // Token reward amount (e.g. $100.00)

  totalSlots  Int      @default(100)
  filledSlots Int      @default(0)

  tags        String[] @default([])
  requiredSkills  String[] @default([]) // skill names agent must have to accept
  requireVerified Boolean  @default(false) // only accept agents with verified (scanned) skills
  tasks           Json     @default("[]")  // QuestTask[] — social task definitions

  rewardTiers   Json?                   // LEADERBOARD: [40, 25, 15, 20] = % per rank (last = split among rest)
  network     String?                 // blockchain name (e.g. "Base", "BNB Smart Chain")
  drawTime    DateTime?               // Lucky Draw deadline

  expiresAt   DateTime?
  startAt     DateTime?               // null = immediately live after funding

  // Ownership / claim fields
  creatorAgentId      String?             // Agent who created this quest (Flow B)
  creatorTelegramId   BigInt?             // Telegram user who claimed this quest
  creatorEmail        String?             // Email of creator (alternative identity)
  creatorUserId       String?             // Optional — linked Supabase user
  claimToken          String?   @unique   // Token for claiming ownership (cleared on claim)
  claimTokenExpiresAt DateTime?           // 48h expiry
  claimedAt           DateTime?           // null = unclaimed
  previewToken        String?   @unique   // Permanent preview link token (survives claim)

  // Funding
  fundingMethod       String?             // "stripe" | "crypto"
  fundingStatus       String   @default("unfunded") // unfunded, pending, confirmed, refunded
  stripeSessionId     String?  @unique
  stripePaymentId     String?
  cryptoTxHash        String?
  cryptoChainId       Int?                // e.g. 8453 (Base)
  fundedAt            DateTime?
  fundedAmount        Int?                // actual amount received (same unit as rewardAmount)

  // Refund
  refundStatus        String?             // pending, completed
  refundAmount        Int?
  refundTxHash        String?
  refundedAt          DateTime?

  // Crypto escrow — on-chain data
  tokenAddress        String?             // ERC20 contract address on-chain (null for native)
  tokenDecimals       Int?                // 6 for USDC, 18 for ETH
  sponsorWallet       String?             // Sponsor's wallet address
  escrowQuestId       String?             // bytes32 hex for contract reference

  // LLM Key Bonus Reward (on-claw-llm-server)
  llmKeyRewardEnabled Boolean @default(false)
  llmKeyTokenLimit    Int?    @default(1000000)

  // LLM Model Reward (LLMTOKEN_OPENROUTER)
  llmModelId           String?
  llmModel             LlmModel? @relation(fields: [llmModelId], references: [id])
  tokenBudgetPerWinner Decimal?  @db.Decimal(18, 6)  // USD budget per winner

  // Collaboration
  totalFunded     Decimal  @default(0) @db.Decimal(36, 18)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  participations QuestParticipation[]
  collaborators  QuestCollaborator[]
  deposits       QuestDeposit[]

  @@index([claimToken])
  @@index([llmModelId])
  @@index([previewToken])
  @@index([creatorTelegramId])
  @@index([creatorAgentId])
  @@index([creatorUserId])
  @@index([status, createdAt])
}

// ─── LLM Model Catalog ────────────────────────────────────────────────────────

model LlmModel {
  id               String   @id @default(uuid())
  openrouterId     String   @unique  // e.g. "anthropic/claude-sonnet-4.6"
  name             String           // "Claude Sonnet 4.6"
  provider         String           // "Anthropic"
  tier             String   @default("standard") // budget | mid | premium
  inputPricePer1M  Decimal  @db.Decimal(10, 4)   // sell price $/1M input tokens (incl. 6% markup)
  outputPricePer1M Decimal  @db.Decimal(10, 4)   // sell price $/1M output tokens (incl. 6% markup)
  contextWindow    Int                             // max context tokens
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  quests           Quest[]

  @@index([isActive, outputPricePer1M])
}

model QuestCollaborator {
  id          String    @id @default(uuid())
  questId     String
  quest       Quest     @relation(fields: [questId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  inviteToken String    @unique  // "collab_<hex>"
  invitedBy   String?            // userId of who invited
  acceptedAt  DateTime?          // null = pending invite
  expiresAt   DateTime           // 7-day expiry
  createdAt   DateTime  @default(now())

  @@unique([questId, userId])
  @@index([questId])
  @@index([inviteToken])
}

model QuestDeposit {
  id            String   @id @default(uuid())
  questId       String                        // logical quest UUID
  quest         Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)
  escrowQuestId String                        // on-chain questId bytes32 (main or sub)
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  amount        Decimal  @db.Decimal(36, 18)  // human-readable (e.g. 200.00)
  tokenAddress  String
  chainId       Int
  txHash        String?                       // filled when poller confirms
  walletAddress String   @default("")         // depositor's wallet
  status        String   @default("pending")  // pending | confirmed | refunded
  createdAt     DateTime @default(now())

  @@index([questId])
  @@index([escrowQuestId])
  @@index([userId])
}

model QuestParticipation {
  id        String   @id @default(uuid())
  questId   String
  quest     Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)
  userId    String?  // null for agent-only participations
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentId   String?  // null until user links an agent
  agent     Agent?   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  status          String   @default("in_progress") // in_progress, submitted, completed, failed
  proof           Json?    // Store proof details
  tasksCompleted  Int      @default(0)
  tasksTotal      Int      @default(5)
  payoutAmount    Float?   // null = N/A, value = paid/pending amount
  payoutStatus    String   @default("na") // na, pending, paid
  payoutTxHash    String?  // on-chain tx hash of distribute()
  payoutWallet    String?  // winner's wallet address

  // LLM Token payout (OpenRouter API keys)
  payoutTokenProvider  String?   // "openrouter"
  payoutTokenAmount    Decimal?  @db.Decimal(36, 18) // e.g. $100.00
  payoutTokenApiKey    String?   // sk-or-v1-xxxx (generated API key)
  payoutTokenKeyId     String?   // OpenRouter key ID (for revocation)
  payoutTokenExpiresAt DateTime? // When key auto-expires
  payoutTokenStatus    String?   // pending_key_creation | key_sent | used | expired

  // LLM Key Bonus Reward (on-claw-llm-server)
  llmRewardApiKey   String?
  llmRewardIssuedAt DateTime?

  joinedAt    DateTime @default(now())
  completedAt DateTime?

  @@unique([questId, userId]) // One participation per user per quest (nulls are distinct)
  @@unique([questId, agentId]) // One participation per agent per quest
}

model AgentSkill {
  id        String   @id @default(uuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  name      String   // e.g. "sponge-wallet", "onchain-actions"
  version   String?  // e.g. "1.0.0" — null if unknown (Claude Code)
  source    String   @default("unknown") // "clawhub", "mcp", "manual"
  publisher String?  // e.g. "paysponge", "openclaw", "leeknowsai"
  meta      Json?    // extra metadata (tool names for MCP, description, etc.)
  verified  Boolean  @default(false) // true when reported via scan tool
  platform  String?  // "openclaw" | "cloudage" | "agentforge" | "claude" | "claude_code"
  scannedAt DateTime? // last scan timestamp

  lastSeenAt DateTime @default(now()) // updated each time agent re-reports
  createdAt  DateTime @default(now())

  @@unique([agentId, name]) // one record per skill per agent
  @@index([agentId])
  @@index([name])
}

model AgentLog {
  id        String   @id @default(uuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  type      String   // QUEST_START, QUEST_COMPLETE, ERROR, INFO
  message   String
  meta      Json?

  createdAt DateTime @default(now())

  @@index([agentId])
  @@index([createdAt])
}

model WalletLink {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  address   String   // checksummed Ethereum address
  chainId   Int?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, address])
  @@index([userId])
  @@index([address])
}

model EscrowCursor {
  chainId   Int      @id
  lastBlock BigInt
  updatedAt DateTime @updatedAt
}

// ─── Chain & RPC Registry ────────────────────────────────────────────────────

model Chain {
  id              Int      @id         // chainId (e.g. 56, 8453)
  name            String
  shortName       String
  nativeCurrency  Json                 // { symbol, name, decimals }
  explorerUrl     String
  isTestnet       Boolean  @default(false)
  isEscrowEnabled Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rpcs            ChainRpc[]
  contracts       EscrowContract[]
}

model ChainRpc {
  id        String   @id @default(uuid())
  chainId   Int
  chain     Chain    @relation(fields: [chainId], references: [id])
  url       String
  provider  String?                   // "public", "alchemy", "quicknode", "custom"
  priority  Int      @default(10)     // lower number = higher priority
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([chainId, url])
  @@index([chainId, isActive, priority])
}

model EscrowContract {
  id         String    @id @default(uuid())
  chainId    Int
  chain      Chain     @relation(fields: [chainId], references: [id])
  address    String
  isActive   Boolean   @default(true)
  deployedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([chainId, address])
  @@index([chainId, isActive])
}

// ─── Waitlist ─────────────────────────────────────────────────────────────────

model WaitlistEntry {
  id              String   @id @default(uuid())
  email           String?  @unique              // Email address (for simple waitlist signup)
  telegramId      BigInt?  @unique              // Telegram user ID — set after bot join (nullable until then)
  telegramHandle  String?                       // @username (may be absent)
  firstName       String?                       // First name from Telegram ctx.from
  role            String?                       // "agent-owner" | "sponsor" (set via web popup)
  userId          String?  @unique              // linked Prisma User.id (set when user links Telegram)
  user            User?    @relation(fields: [userId], references: [id])
  accessToken     String?  @unique              // UUID generated on web click — links web session to bot join
  referralCode    String   @unique              // 8-char hex — used in referral links
  referredBy      String?                       // referralCode of the referrer
  referralCount   Int      @default(0)          // how many joined using this entry's code
  referralBonus   Int      @default(0)          // total spots gained from referrals (10 per referral)
  position        Int      @default(0)          // base waitlist rank — 0 = pending; set when user joins via Telegram
  effectivePosition Int     @default(0)          // display rank (1-based); 0 = pending, only set for joined entries
  createdAt       DateTime @default(now())

  @@index([referralCode])
  @@index([referredBy])
  @@index([position])
  @@index([effectivePosition])
  @@index([userId])
}

// ─── Telegram Bot Chat Logs ──────────────────────────────────────────────────

model BotChatLog {
  id         String   @id @default(uuid())
  telegramId BigInt
  direction  String   // "inbound" | "outbound"
  type       String   // "command" | "chat" | "token" | "session" | "bot_response"
  text       String
  meta       Json?    // { command: "/start" } or { model: "claude-haiku", tokens: 80 }
  createdAt  DateTime @default(now())

  @@index([telegramId, createdAt])
  @@index([type])
}

// ─── GitHub Bounty ────────────────────────────────────────────────────────────

model GitHubBounty {
  id            String    @id @default(uuid())
  creatorUserId String
  creator       User      @relation(fields: [creatorUserId], references: [id])
  repoOwner     String                        // e.g. "facebook"
  repoName      String                        // e.g. "react"
  issueNumber   Int?                          // optional linked GitHub issue
  issueUrl      String?                       // https://github.com/owner/repo/issues/123
  title         String
  description   String    @db.Text
  rewardAmount  Decimal   @db.Decimal(18, 6)
  rewardType    String                        // USDC | USD | LLM_KEY
  status        String    @default("draft")   // draft | live | completed | cancelled
  questType     String    @default("fcfs")    // fcfs | leaderboard
  maxWinners    Int       @default(1)
  deadline      DateTime?

  // Funding — Stripe (USD) or escrow (USDC)
  fundingStatus       String   @default("unfunded") // unfunded | pending | confirmed
  stripeSessionId     String?  @unique
  stripePaymentId     String?
  escrowQuestId       String?                 // bytes32 hex for on-chain reference

  // LLM Key reward (issued on approve)
  llmKeyTokenLimit    Int?     @default(1000000)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  submissions   GitHubBountySubmission[]

  @@index([creatorUserId])
  @@index([status])
  @@index([repoOwner, repoName])
}

model GitHubBountySubmission {
  id        String    @id @default(uuid())
  bountyId  String
  bounty    GitHubBounty @relation(fields: [bountyId], references: [id], onDelete: Cascade)
  userId    String?                           // null if submitted by agent
  user      User?     @relation(fields: [userId], references: [id])
  agentId   String?                           // null if submitted by human
  agent     Agent?    @relation(fields: [agentId], references: [id])
  prUrl     String
  prNumber  Int
  status    String    @default("pending")     // pending | approved | rejected

  // Reward payout
  llmRewardApiKey   String?
  llmRewardIssuedAt DateTime?

  createdAt DateTime  @default(now())

  @@unique([bountyId, userId])   // one submission per user per bounty
  @@unique([bountyId, agentId])  // one submission per agent per bounty
  @@index([bountyId])
  @@index([userId])
}

// External data — crawled from ClawHub registry
model clawhub_skills {
  id                  String    @id @default(uuid()) @db.Uuid
  clawhub_id          String    @unique
  slug                String    @unique
  display_name        String
  summary             String?
  downloads           Int       @default(0)
  installs_all_time   Int       @default(0)
  installs_current    Int       @default(0)
  stars               Int       @default(0)
  comments            Int       @default(0)
  versions            Int       @default(0)
  owner_handle        String?
  owner_display_name  String?
  owner_image         String?
  latest_version      String?
  latest_version_id   String?
  badges              Json      @default("{}")
  tags                Json      @default("{}")
  parsed_clawdis      Json?
  clawhub_created_at  DateTime? @db.Timestamptz
  clawhub_updated_at  DateTime? @db.Timestamptz
  crawled_at          DateTime  @default(now()) @db.Timestamptz

  // Web3 classification
  is_web3             Boolean   @default(false)
  web3_auto_detected  Boolean   @default(false)
  web3_admin_override Boolean?
  web3_category       String?
  featured            Boolean   @default(false)
  featured_order      Int?

  @@index([downloads(sort: Desc)])
  @@index([stars(sort: Desc)])
  @@index([owner_handle])
  @@index([crawled_at])
  @@index([is_web3, downloads(sort: Desc)])

  @@map("clawhub_skills")
}

model web3_skill_submissions {
  id              String    @id @default(uuid()) @db.Uuid
  name            String
  slug            String    @unique
  summary         String
  description     String?
  website_url     String?
  github_url      String?
  logo_url        String?
  category        String
  tags            String[]  @default([])
  submitted_by    String
  status          String    @default("pending")   // pending | approved | rejected
  review_note     String?
  reviewed_by     String?
  reviewed_at     DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz

  submitter       User      @relation("SkillSubmitter", fields: [submitted_by], references: [id])
  reviewer        User?     @relation("SkillReviewer", fields: [reviewed_by], references: [id])

  @@index([status])
  @@index([category])
  @@index([submitted_by])
  @@map("web3_skill_submissions")
}
