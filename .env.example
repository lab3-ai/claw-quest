DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/clawquest?schema=public"
DIRECT_URL="postgresql://postgres:postgrespassword@localhost:5432/clawquest?schema=public"

# Testnet DB (optional — for admin dashboard dual-DB monitoring)
DATABASE_URL_TESTNET=""

# Auth
JWT_SECRET="supersecret"
ADMIN_JWT_SECRET="admin_supersecret"
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=""

# Integration
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""   # @your_bot_username (without @)
DISCORD_BOT_TOKEN=""
DISCORD_CLIENT_ID=""

# X (Twitter) OAuth 2.0 — for real social task verification
X_CLIENT_ID=""             # X OAuth 2.0 app client ID
X_CLIENT_SECRET=""         # X OAuth 2.0 app client secret
X_BEARER_TOKEN=""          # X API v2 Bearer Token (for tweet verification)

# GitHub OAuth — for GitHub Bounty feature (login via Supabase)
GITHUB_CLIENT_ID=""        # GitHub OAuth App client ID (add to Supabase Auth → Providers → GitHub)
GITHUB_CLIENT_SECRET=""    # GitHub OAuth App client secret
GITHUB_TOKEN=""            # GitHub PAT (server-side token for public repo API calls)

# RapidAPI — for agent X verification (twttrapi)
RAPID_API_KEY=""                           # RapidAPI key from https://rapidapi.com/hub
TWITTER_VERIFY_MENTION_CLAWQUEST=true      # Require tweet to mention @clawquest (default: true)

# AI Chat — Claude Haiku for Telegram bot conversational responses (optional)
ANTHROPIC_API_KEY=""

# MiniMax AI — for bounty analysis LLM fallback (cheaper alternative to Anthropic)
# Get key at: https://www.minimaxi.com/user-center/basic-information/interface-key
MINIMAX_API_KEY=""

# OpenRouter — Management API key for creating LLM token reward keys
OPENROUTER_MANAGEMENT_KEY=""

# Telegram OIDC (Login with Telegram)
TELEGRAM_CLIENT_ID=""          # Bot ID from BotFather
TELEGRAM_CLIENT_SECRET=""      # From BotFather OIDC settings

# Server
PORT=3000
CORS_ORIGIN="http://localhost:5173"

# Frontend
FRONTEND_URL="http://localhost:5173"
VITE_API_URL="http://localhost:3000"
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
VITE_TELEGRAM_CLIENT_ID=""         # Bot ID (same as TELEGRAM_CLIENT_ID)
VITE_WALLETCONNECT_PROJECT_ID=""

# Escrow network mode (testnet = Base Sepolia + BSC Testnet, mainnet = Base + BNB)
ESCROW_NETWORK_MODE=testnet                # testnet | mainnet
VITE_ESCROW_NETWORK_MODE=testnet           # frontend counterpart

# Escrow — active chains (comma-separated chain IDs, source of truth)
ESCROW_CHAIN_IDS=84532                  # add chains here: 84532,8453,56
ESCROW_CHAIN_ID=84532                   # default chain (84532 = Base Sepolia, 8453 = Base)

# Escrow — contract addresses
# Base Sepolia (testnet) — LIVE contract
ESCROW_CONTRACT_84532=0xd771ca2fa508a462f07269ec3745d33b4dbc24b0
# BSC Testnet (97) — deploy contract then add:
# ESCROW_CONTRACT_97=0x...
# Base mainnet (8453):
# ESCROW_CONTRACT_8453=0x...
# Shared CREATE2 address (fallback for all chains if per-chain not set):
ESCROW_CONTRACT=""

# Operator key (hot wallet for distribute/refund — must have OPERATOR_ROLE on contract)
# OPERATOR_PRIVATE_KEY="0x..."

# Escrow poller settings
ESCROW_POLL_INTERVAL=15000              # ms between polls (default 15s)
ESCROW_CONFIRMATION_BLOCKS=5           # blocks behind tip for re-org safety (default 5)

# Custom RPC URLs (optional — defaults to public endpoints)
# RPC_URL_<chainId>=https://...         # canonical format: RPC_URL_8453, RPC_URL_84532
# RPC_URL_BASE="https://..."            # legacy format (still supported)

# Stripe Connect (fiat payments — optional, server starts without it)
STRIPE_SECRET_KEY=""                    # sk_test_... or sk_live_...
STRIPE_WEBHOOK_SECRET=""               # whsec_... (from Stripe Dashboard or CLI)
# STRIPE_PLATFORM_FEE_PERCENT="0"      # Platform fee on distributions (0 = no fee)

# Frontend — Stripe publishable key
VITE_STRIPE_PUBLISHABLE_KEY=""         # pk_test_... or pk_live_...

# LLM Server (apps/llm-server — Cloudflare Workers)
LLM_SERVER_URL=""                      # Internal URL of apps/llm-server (e.g. https://llm-server.your-worker.workers.dev)
LLM_SERVER_SECRET_KEY=""               # SECRET_KEY set via `wrangler secret put SECRET_KEY`
LLM_ADMIN_KEY=""                       # Admin key for LLM server management
VITE_LLM_SERVER_URL=""                 # Public URL shown to winners (e.g. https://llm.clawquest.ai)
