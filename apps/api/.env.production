# ─────────────────────────────────────────────
# ClawQuest API — Production Environment
# Railway automatically provides DATABASE_URL
# Set remaining vars in Railway dashboard
# ─────────────────────────────────────────────

# ── Database (Railway auto-provisions) ───────
# Railway auto-injects DATABASE_URL from PostgreSQL add-on
# Uncomment DIRECT_URL if using connection pooling:
# DIRECT_URL="<railway-direct-connection-url>"

# ── Server ────────────────────────────────────
# Railway auto-injects PORT (typically 3000)
# PORT=3000

# CORS origins (comma-separated, no spaces after commas)
# Example: https://dashboard.yourdomain.com,https://admin.yourdomain.com
CORS_ORIGIN="https://clawquest.ai,https://www.clawquest.ai,https://admin.clawquest.ai"

# URL of the frontend app (used for OAuth redirect URIs)
FRONTEND_URL="https://clawquest.ai"

# ── Auth ──────────────────────────────────────
# Legacy JWT secret (kept for backward compat)
JWT_SECRET="<production-jwt-secret-min-32-chars>"

# ── Supabase ──────────────────────────────────
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="<your-supabase-anon-key>"
SUPABASE_SERVICE_ROLE_KEY="<your-supabase-service-role-key>"

# ── X (Twitter) OAuth ─────────────────────────
X_CLIENT_ID="<your-x-client-id>"
X_CLIENT_SECRET="<your-x-client-secret>"
TWITTER_VERIFY_MENTION_CLAWQUEST="true"

# ── Discord OAuth + Bot ───────────────────────
DISCORD_CLIENT_ID="<your-discord-client-id>"
DISCORD_CLIENT_SECRET="<your-discord-client-secret>"
DISCORD_BOT_TOKEN="<your-discord-bot-token>"

# ── Telegram Bot + OIDC ───────────────────────
TELEGRAM_BOT_TOKEN="<your-telegram-bot-token>"
TELEGRAM_BOT_USERNAME="<YourBotUsername>"
TELEGRAM_CLIENT_ID="<your-telegram-client-id>"
TELEGRAM_CLIENT_SECRET="<your-telegram-client-secret>"

# ── Stripe Connect ────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Escrow / Blockchain ───────────────────────
ESCROW_NETWORK_MODE="mainnet"
ESCROW_CHAIN_ID="56"
RPC_URL_BASE_SEPOLIA="https://sepolia.base.org"
ESCROW_CONTRACT="<mainnet-contract-address>"
ESCROW_CONTRACT_84532="<base-sepolia-contract-address>"
ESCROW_CONTRACT_56="<bnb-chain-contract-address>"
OPERATOR_PRIVATE_KEY="<operator-wallet-private-key>"

# ── External APIs ─────────────────────────────
RAPID_API_KEY="<your-rapid-api-key>"

# ── LLM Server ────────────────────────────────
LLM_SERVER_URL="https://clawquest-llm-server.lab3-dev.workers.dev"
LLM_SERVER_SECRET_KEY="<llm-server-secret-key>"
