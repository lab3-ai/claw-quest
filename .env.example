DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/clawquest?schema=public"
DIRECT_URL="postgresql://postgres:postgrespassword@localhost:5432/clawquest?schema=public"

# Testnet DB (optional — for admin dashboard dual-DB monitoring)
# DATABASE_URL_TESTNET="postgresql://..."

# Auth
JWT_SECRET="supersecret"
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=""

# Integration
TELEGRAM_BOT_TOKEN=""

# Telegram OIDC (Login with Telegram)
TELEGRAM_CLIENT_ID=""          # Bot ID from BotFather
TELEGRAM_CLIENT_SECRET=""      # From BotFather OIDC settings

# Frontend
FRONTEND_URL="http://localhost:5173"
VITE_API_URL="http://localhost:3000"
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
VITE_TELEGRAM_CLIENT_ID=""         # Bot ID (same as TELEGRAM_CLIENT_ID)
VITE_WALLETCONNECT_PROJECT_ID=""

# Environment (testnet/mainnet switching)
ENABLE_TESTNETS=true                    # true for dev, false for production
VITE_ENABLE_TESTNETS=true               # frontend counterpart

# Escrow — per-chain contract addresses
ESCROW_CHAIN_ID=84532                   # default chain (84532 = Base Sepolia, 8453 = Base)
# ESCROW_CONTRACT_84532="0x..."         # Base Sepolia contract
# ESCROW_CONTRACT_8453="0x..."          # Base Mainnet contract
# ESCROW_CONTRACT_42161="0x..."         # Arbitrum contract (when deployed)

# Legacy single contract (backward compat — use per-chain vars above instead)
# ESCROW_CONTRACT="0x..."

# Operator key (hot wallet for distribute/refund)
# OPERATOR_PRIVATE_KEY="0x..."

# Escrow poller settings
ESCROW_POLL_INTERVAL=15000              # ms between polls (default 15s)
ESCROW_CONFIRMATION_BLOCKS=5           # blocks behind tip for re-org safety (default 5)

# Custom RPC URLs (optional — defaults to public endpoints)
# RPC_URL_BASE="https://mainnet.base.org"
# RPC_URL_BASE_SEPOLIA="https://sepolia.base.org"
# RPC_URL_ETH="https://eth.llamarpc.com"
# RPC_URL_BNB="https://bsc-dataseed.binance.org"
# RPC_URL_ARB="https://arb1.arbitrum.io/rpc"
# RPC_URL_POLYGON="https://polygon-rpc.com"
