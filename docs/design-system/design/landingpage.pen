                              "type": "text",
                              "id": "gPIf1",
                              "name": "fq1qt",
                              "fill": "$fg-1",
                              "content": "What is ClawQuest?",
                              "fontFamily": "Geist Mono",
                              "fontSize": 16,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "lqUJj",
                              "name": "fq1icon",
                              "fill": "$fg-3",
                              "content": "+",
                              "fontFamily": "Geist Mono",
