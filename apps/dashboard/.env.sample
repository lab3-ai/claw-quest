# ──────────────────────────────────────────────────
# ClawQuest Dashboard — Environment Variables Sample
# Copy to .env and fill in your values
# ──────────────────────────────────────────────────

# ── API ────────────────────────────────────────────
# URL of the ClawQuest API server
VITE_API_URL="http://localhost:3000"

# ── Supabase ───────────────────────────────────────
# Get from https://supabase.com/dashboard/project/<id>/settings/api
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# ── WalletConnect ──────────────────────────────────
# Get project ID at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID="your_walletconnect_project_id"

# ── Telegram Login Widget ──────────────────────────
# Same as TELEGRAM_CLIENT_ID in API (bot ID from @BotFather)
VITE_TELEGRAM_CLIENT_ID="your_telegram_bot_id"

# ── Stripe ─────────────────────────────────────────
# Publishable key only (never use secret key in frontend)
# Get from https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ── Escrow / Blockchain ────────────────────────────
# testnet | mainnet — must match API ESCROW_NETWORK_MODE
VITE_ESCROW_NETWORK_MODE="testnet"
