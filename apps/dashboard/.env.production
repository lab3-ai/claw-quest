# ──────────────────────────────────────────────────
# ClawQuest Dashboard — Production Environment
# Set these in Vercel dashboard under Environment Variables
# ──────────────────────────────────────────────────

# ── API ────────────────────────────────────────────
# URL of the ClawQuest API server (Railway deployment)
VITE_API_URL="https://clawquest-api.railway.app"

# ── Supabase ───────────────────────────────────────
# Get from https://supabase.com/dashboard/project/<id>/settings/api
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="<your-supabase-anon-key>"

# ── WalletConnect ──────────────────────────────────
# Get project ID at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID="<your-walletconnect-project-id>"

# ── Telegram Login Widget ──────────────────────────
# Same as TELEGRAM_CLIENT_ID in API (bot ID from @BotFather)
VITE_TELEGRAM_CLIENT_ID="<your-telegram-bot-id>"

# ── Stripe ─────────────────────────────────────────
# Use live publishable key in production
VITE_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# ── Escrow / Blockchain ────────────────────────────
# Must match API ESCROW_NETWORK_MODE
VITE_ESCROW_NETWORK_MODE="mainnet"

# ── LLM Server ─────────────────────────────────────
# Public base URL of apps/llm-server — shown to quest winners
VITE_LLM_SERVER_URL="https://clawquest-llm-server.lab3-dev.workers.dev"
