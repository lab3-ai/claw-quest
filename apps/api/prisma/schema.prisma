generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  supabaseId  String?  @unique  // Supabase Auth user UUID
  email       String   @unique
  password    String?            // Legacy — kept for backward compat
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agents      Agent[]
}

model Agent {
  id                    String    @id @default(uuid())
  ownerId               String?
  owner                 User?     @relation(fields: [ownerId], references: [id])
  name                  String
  status                String    @default("idle") // idle, questing, offline
  activationCode        String?   @unique
  agentApiKey           String?   @unique  // issued on /agents/register — used by agents as Bearer token
  verificationToken     String?   @unique  // for agent-first registration claim flow
  verificationExpiresAt DateTime?           // 24h expiry for verification token

  TelegramLink   TelegramLink?
  logs           AgentLog[]
  participations QuestParticipation[]
  skills         AgentSkill[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([ownerId])
  @@index([agentApiKey])
  @@index([verificationToken])
}

model TelegramLink {
  id          String   @id @default(uuid())
  agentId     String   @unique
  agent       Agent    @relation(fields: [agentId], references: [id])
  telegramId  BigInt   @unique
  username    String?
  firstName   String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Quest {
  id          String   @id @default(uuid())
  title       String
  description String
  sponsor     String   @default("System")
  
  type        String   @default("FCFS") // FCFS, LEADERBOARD, LUCKY_DRAW
  status      String   @default("draft") // draft, live, scheduled, pending, completed
  
  rewardAmount Int
  rewardType   String   @default("USDC")
  
  totalSlots  Int      @default(100)
  filledSlots Int      @default(0)

  tags        String[] @default([])
  requiredSkills String[] @default([]) // skill names agent must have to accept

  expiresAt   DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt // Added updatedAt
  
  participations QuestParticipation[]
}

model QuestParticipation {
  id        String   @id @default(uuid())
  questId   String
  quest     Quest    @relation(fields: [questId], references: [id])
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id])

  status          String   @default("in_progress") // in_progress, submitted, completed, failed
  proof           Json?    // Store proof details
  tasksCompleted  Int      @default(0)
  tasksTotal      Int      @default(5)
  payoutAmount    Float?   // null = N/A, value = paid/pending amount
  payoutStatus    String   @default("na") // na, pending, paid

  joinedAt    DateTime @default(now())
  completedAt DateTime?

  @@unique([questId, agentId]) // One participation per agent per quest
}

model AgentSkill {
  id        String   @id @default(uuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id])

  name      String   // e.g. "sponge-wallet", "onchain-actions"
  version   String?  // e.g. "1.0.0" — null if unknown (Claude Code)
  source    String   @default("unknown") // "clawhub", "mcp", "manual"
  publisher String?  // e.g. "paysponge", "openclaw", "leeknowsai"
  meta      Json?    // extra metadata (tool names for MCP, description, etc.)

  lastSeenAt DateTime @default(now()) // updated each time agent re-reports
  createdAt  DateTime @default(now())

  @@unique([agentId, name]) // one record per skill per agent
  @@index([agentId])
  @@index([name])
}

model AgentLog {
  id        String   @id @default(uuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id])
  type      String   // QUEST_START, QUEST_COMPLETE, ERROR, INFO
  message   String
  meta      Json?
  
  createdAt DateTime @default(now())
  
  @@index([agentId])
  @@index([createdAt])
}
