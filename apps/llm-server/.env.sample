# ─────────────────────────────────────────────────────
# ClawQuest LLM Server — Environment Variables Sample
# Deployed as Cloudflare Worker — set secrets via:
#   wrangler secret put <NAME>
# ─────────────────────────────────────────────────────

# ── D1 Database ───────────────────────────────────────
# D1 is managed via wrangler — no connection string needed
# 1. Create DB:  wrangler d1 create clawquest-llm
# 2. Paste the returned database_id into wrangler.toml
# 3. Apply schema locally: pnpm db:migrate:local
# 4. Apply schema remote:  pnpm db:migrate

# ── Auth Secrets ──────────────────────────────────────
# Shared with apps/api as LLM_SERVER_SECRET_KEY
SECRET_KEY="clawquest2026"
# For admin upstream URL management endpoints
ADMIN_SECRET_KEY="clawquest2026"

# ── Default Upstream LLM ──────────────────────────────
# Used when no upstream URLs are configured in the database
# e.g. https://openrouter.ai/api/v1
UPSTREAM_BASE_URL=""
UPSTREAM_API_KEY=""
# Optional: override default model
DEFAULT_MODEL=""
