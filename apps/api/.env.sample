# ─────────────────────────────────────────────
# ClawQuest API — Environment Variables Sample
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# ── Database (Supabase / PostgreSQL) ──────────
# Use connection pooling URL for app queries
DATABASE_URL="postgresql://postgres:<password>@<host>:6543/<db>?pgbouncer=true"
# Use direct URL for Prisma migrations
DIRECT_URL="postgresql://postgres:<password>@<host>:5432/<db>"

# ── Server ────────────────────────────────────
PORT=3000
# URL of the frontend app (used for OAuth redirect URIs)
FRONTEND_URL="http://localhost:5173"

# ── Auth ──────────────────────────────────────
# Legacy JWT secret (kept for backward compat)
JWT_SECRET="your_jwt_secret_here"

# ── Supabase ──────────────────────────────────
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ── X (Twitter) OAuth ─────────────────────────
# Create app at https://developer.twitter.com/en/portal/projects-and-apps
# Required scopes: tweet.read users.read follows.read like.read offline.access
X_CLIENT_ID="your_x_client_id"
X_CLIENT_SECRET="your_x_client_secret"
# Set to "true" to require @ClawQuest mention in post tasks
TWITTER_VERIFY_MENTION_CLAWQUEST="false"

# ── Discord OAuth + Bot ───────────────────────
# Create app at https://discord.com/developers/applications
# Bot requires: Server Members Intent (privileged), Read Message History
# OAuth scopes: identify email guilds guilds.members.read
DISCORD_CLIENT_ID="your_discord_client_id"
DISCORD_CLIENT_SECRET="your_discord_client_secret"
# Bot token — required for join_server / verify_role task verification
# Invite bot to all Discord servers used in quests
DISCORD_BOT_TOKEN="your_discord_bot_token"

# ── Telegram Bot + OIDC ───────────────────────
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
TELEGRAM_BOT_USERNAME="YourBotUsername"
# For Telegram Login Widget OIDC flow
TELEGRAM_CLIENT_ID="your_telegram_client_id"
TELEGRAM_CLIENT_SECRET="your_telegram_client_secret"

# ── Stripe Connect ────────────────────────────
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Webhook secret from Stripe CLI or dashboard
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Escrow / Blockchain ───────────────────────
# testnet | mainnet
ESCROW_NETWORK_MODE="testnet"
ESCROW_CHAIN_ID="84532"
RPC_URL_BASE_SEPOLIA="https://sepolia.base.org"
# Deployed escrow contract addresses
ESCROW_CONTRACT="0x..."
ESCROW_CONTRACT_84532="0x..."
ESCROW_CONTRACT_56="0x..."
# Operator wallet private key (DO NOT commit real key)
OPERATOR_PRIVATE_KEY="0x..."

# ── External APIs ─────────────────────────────
# RapidAPI key (used for additional social verification)
RAPID_API_KEY="your_rapid_api_key"

# ── LLM Server ────────────────────────────────
# URL of apps/llm-server Cloudflare Worker
LLM_SERVER_URL="https://clawquest-llm-server.lab3-dev.workers.dev"
# Must match SECRET_KEY set via `wrangler secret put SECRET_KEY` in llm-server
LLM_SERVER_SECRET_KEY=""

# ── OKX OnchainOS ───────────────────────────
# Get keys at https://web3.okx.com/onchain-os/dev-portal
OKX_API_KEY=""
OKX_API_SECRET=""
OKX_API_PASSPHRASE=""
