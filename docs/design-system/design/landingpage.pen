                            {
                              "type": "text",
                              "id": "bSKrW",
                              "name": "fq3qt",
                              "fill": "$fg-1",
                              "content": "How are rewards paid out?",
                              "fontFamily": "Geist Mono",
                              "fontSize": 16,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "e4JPn",
                              "name": "fq3icon",
                              "fill": "$fg-3",
                              "content": "+",
