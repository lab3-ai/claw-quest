{
    "name": "@clawquest/api",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "tsx watch src/app.ts",
        "build": "tsup src/app.ts --format cjs,esm",
        "start": "node dist/app.js",
        "db:migrate": "prisma migrate dev",
        "db:deploy": "prisma migrate deploy",
        "db:seed": "tsx prisma/seed.ts",
        "db:create-admin": "tsx prisma/create-admin.ts",
        "db:seed:skills": "tsx prisma/clawhub-skills-seed.ts",
        "db:studio": "prisma studio",
        "test": "vitest run"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.78.0",
        "@clawquest/shared": "workspace:*",
        "@fastify/cors": "^11.2.0",
        "@fastify/rate-limit": "^10.3.0",
        "@fastify/swagger": "^9.5.1",
        "@prisma/client": "^5.10.2",
        "@scalar/fastify-api-reference": "^1.44.25",
        "@supabase/supabase-js": "^2.45.0",
        "bcryptjs": "^3.0.3",
        "dotenv": "^16.4.5",
        "fastify": "^5.7.2",
        "fastify-raw-body": "^5.0.0",
        "fastify-type-provider-zod": "^6.1.0",
        "grammy": "^1.40.0",
        "jose": "^6.1.3",
        "prisma": "^5.10.2",
        "stripe": "^20.4.0",
        "telegraf": "^4.16.3",
        "viem": "^2.46.2",
        "zod": "^4.1.5"
    },
    "devDependencies": {
        "@types/bcryptjs": "^3.0.0",
        "@types/node": "^20.11.24",
        "tsup": "^8.0.2",
        "tsx": "^4.7.1",
        "typescript": "^5.3.3",
        "vitest": "^4.0.18"
    }
}